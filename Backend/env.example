# ============================================================
# NL-SQL Agent — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# PostgreSQL connection
PG_HOST=your-db-host.example.com
PG_PORT=5432
PG_DATABASE=your_database_name
PG_USER=nlsql_reader
PG_PASSWORD=your_readonly_password

# Set to "true" if your cloud PostgreSQL requires SSL (most do)
# e.g. Supabase, RDS, Neon, Railway — set this to true
PG_SSL=true

# Which Postgres schema to introspect (almost always "public")
PG_SCHEMA=public

# The port this backend server listens on
PORT=3001

# Comma-separated list of frontend origins allowed to call this API
# In production, replace with your actual frontend URL
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Node environment
NODE_ENV=production
